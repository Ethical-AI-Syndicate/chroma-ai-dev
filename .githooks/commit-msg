#!/bin/bash
set -euo pipefail

commit_msg_file="$1"
commit_msg="$(cat "$commit_msg_file")"

schema_files_changed=$(git diff --cached --name-only | rg "(TOOLS|PROMPTS|EVALS|AGENTS|MCP_SERVERS|CLAUDE)\\.md" || true)

if [ -n "$schema_files_changed" ]; then
  if ! printf "%s" "$commit_msg" | rg -q "^(feat|fix|breaking|docs)\((tools|prompts|evals|agents|mcp|claude)\):"; then
    echo "Schema changes require conventional commit format"
    echo "Example: feat(tools): add read_file tool"
    exit 1
  fi
fi
